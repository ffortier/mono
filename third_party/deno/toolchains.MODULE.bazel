http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

BUILD_FILE_CONTENT = """
filegroup(
    name = "{repo_name}",
    srcs = ["{deno}"],
    visibility = ["//visibility:public"],
)
"""

http_archive(
    name = "deno_darwin_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.4/deno-aarch64-apple-darwin.zip"],
    sha256 = "65ccaf62b0e9ded08c02cb102d54c1c9f8249592218cb3cb038eb818a94cfbf8",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_darwin_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_linux_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.4/deno-x86_64-unknown-linux-gnu.zip"],
    sha256 = "aef56590931e785af10bdab2077a2a01344b620c78b7086b88ebca73962ef25d",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_x86_64", deno = "deno"),
)

http_archive(
    name = "deno_linux_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.4/deno-aarch64-unknown-linux-gnu.zip"],
    sha256 = "d2b99d1c072cab6ec8ececda1a1bd5889a9ea5217fafd9a9a9f5b0e56ef5e9cd",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_windows_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.4/deno-x86_64-pc-windows-msvc.zip"],
    sha256 = "d2a0c8ea92ff852336a5e31293b2224fb75c22c68692c27ede5871ed88bc21fd",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_windows_x86_64", deno = "deno.exe"),
)

register_toolchains("//third_party/deno:all")

resolved = use_repo_rule("@toolchain_utils//toolchain/resolved:defs.bzl", "toolchain_resolved")

resolved(
    name = "resolved-deno",
    toolchain_type = "//third_party/deno:toolchain_type",
)

deno = use_extension("//third_party/deno:extension.bzl", "deno")

deno.install(
    lock = "//:deno.lock",
    config = "//:deno.jsonc",
)

use_repo(deno, "deno")
