http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

BUILD_FILE_CONTENT = """
filegroup(
    name = "{repo_name}",
    srcs = ["{deno}"],
    visibility = ["//visibility:public"],
)
"""

http_archive(
    name = "deno_darwin_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.8/deno-aarch64-apple-darwin.zip"],
    sha256 = "1004913bb6385cde26db96a8a0e94bd752a89bc244317b94e916072b3038a85c",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_darwin_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_linux_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.8/deno-x86_64-unknown-linux-gnu.zip"],
    sha256 = "4aa161f11f2560b6e8dc543c0d96a87d7d208989eb82380bd5c2e263e36bed12",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_x86_64", deno = "deno"),
)

http_archive(
    name = "deno_linux_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.8/deno-aarch64-unknown-linux-gnu.zip"],
    sha256 = "83eae2c5a32eca2b16740cac76c23967e7e3fe1b356cf95625b7b6f4a0f366d8",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_windows_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.8/deno-x86_64-pc-windows-msvc.zip"],
    sha256 = "9348fd9ce2fc0ed10f343f9c48c2fc3dfb36bfd7ca22041fd09b11c70536b984",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_windows_x86_64", deno = "deno.exe"),
)

register_toolchains("//third_party/deno:all")

resolved = use_repo_rule("@toolchain_utils//toolchain/resolved:defs.bzl", "toolchain_resolved")

resolved(
    name = "resolved-deno",
    toolchain_type = "//third_party/deno:toolchain_type",
)

deno = use_extension("//third_party/deno:extension.bzl", "deno")

deno.install(
    lock = "//:deno.lock",
    config = "//:deno.jsonc",
)

use_repo(deno, "deno")
