http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

BUILD_FILE_CONTENT = """
filegroup(
    name = "{repo_name}",
    srcs = ["{deno}"],
    visibility = ["//visibility:public"],
)
"""

http_archive(
    name = "deno_darwin_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.3/deno-aarch64-apple-darwin.zip"],
    sha256 = "2592756b13a1f19dddc0da54950d03f3127c1f3c354e87a975c33efacb322860",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_darwin_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_linux_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.3/deno-x86_64-unknown-linux-gnu.zip"],
    sha256 = "97692549c433fb2967123ee2ad1b7599f2a0b7b745f9919bb791aee1738c966a",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_x86_64", deno = "deno"),
)

http_archive(
    name = "deno_linux_aarch64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.3/deno-aarch64-unknown-linux-gnu.zip"],
    sha256 = "a95cc1f29a5e82350c8b67cfcde2f3fb08591d458d75ce948c7d760e7e1ee816",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_linux_aarch64", deno = "deno"),
)

http_archive(
    name = "deno_windows_x86_64",
    urls = ["https://github.com/denoland/deno/releases/download/v2.7.3/deno-x86_64-pc-windows-msvc.zip"],
    sha256 = "41e0aa83da0d5527959fe53400a705271a3c64e501732c50841e7b60782eb3ce",
    build_file_content = BUILD_FILE_CONTENT.format(repo_name = "deno_windows_x86_64", deno = "deno.exe"),
)

register_toolchains("//third_party/deno:all")

resolved = use_repo_rule("@toolchain_utils//toolchain/resolved:defs.bzl", "toolchain_resolved")

resolved(
    name = "resolved-deno",
    toolchain_type = "//third_party/deno:toolchain_type",
)

deno = use_extension("//third_party/deno:extension.bzl", "deno")

deno.install(
    lock = "//:deno.lock",
    config = "//:deno.jsonc",
)

use_repo(deno, "deno")
